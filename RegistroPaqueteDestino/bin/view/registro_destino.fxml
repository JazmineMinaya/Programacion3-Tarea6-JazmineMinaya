<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.RegistroDestinoController"
      spacing="10"
      alignment="CENTER"
      prefWidth="400"
      prefHeight="500">

    <Label
        text="Registro de Destinos"
        style="-fx-font-size: 15px;"/>

    <TextField
        fx:id="txtNombreDestino"
        promptText="Nombre del Destino"
        prefWidth="350"
        maxWidth="350"/>

    <HBox spacing="10"
          alignment="CENTER">

        <Button
            text="Guardar"
            onAction="#guardarDestino"/>
        <Button
            text="Cargar"
            onAction="#cargarDetallesDestino"/>
    </HBox>

    <TableView 
        fx:id="tablaDestinos"
        prefWidth="350" 
        maxWidth="350" 
        prefHeight="320">
        
        <columnResizePolicy>
            <TableView 
                fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    
        <columns>
            <TableColumn
                fx:id="colNombre"
                text="Destino"/>
        </columns>
    </TableView>

    <Label
        fx:id="lblMensaje"
        text="Esperando acción..."/>
</VBox>